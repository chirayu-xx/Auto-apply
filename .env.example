# ========================
# Auto-Apply Platform
# ========================

# Node environment
NODE_ENV=development

# Backend API
PORT=5000
FRONTEND_URL=http://localhost:3000

# PostgreSQL
POSTGRES_USER=autoapply
POSTGRES_PASSWORD=autoapply123
POSTGRES_DB=autoapply
DATABASE_URL=postgresql://autoapply:autoapply123@localhost:5432/autoapply

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate your own secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_generate_a_64_byte_hex_secret
JWT_REFRESH_SECRET=CHANGE_ME_generate_another_64_byte_hex_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_PORT=8000
OPENROUTER_API_KEY=EXAMPLE_KEY
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# Storage
UPLOAD_DIR=./uploads
